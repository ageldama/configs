HOME           ~                        true
local_bin      ~/local/bin              true
local_scripts  ~/local/scripts          true


#rofi           ~/.config/rofi                    false
dunst           ~/.config/dunst                   F:~/.use-dunst
#input-remapper ~/.config/input-remapper/presets  false
tint2           ~/.config/tint2                   F:~/.use-tint2

urxvt-ext       ~/.urxvt/ext                      ./+pred+/urxvt-ext.pl

ctags           ~/.ctags.d                        F:~/.use-ctags
gdbinit         ~                                 F:~/.use-gdbinit

bashrc.d             ~/.bashrc.d                    F:~/.use-bashrc
bashrc.local.d       ~/.bashrc.local.d              F:~/.use-bashrc
CUSTOM: ./+custom+/bashrc.bash
CUSTOM: ./+custom+/bash_profile.bash

HOME-xorg      ~                        F:~/.use-xorg
HOME-icewm     ~                        F:~/.use-icewm

CUSTOM: ./+custom+/emacs-yas.pl
CUSTOM: ./+custom+/gpg-agent.pl

