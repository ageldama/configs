package require tcltest
namespace import ::tcltest::*

source "[file dirn [file norm [info scr]]]/00.prologue.tcl"

::tcommon begin

critcl::ccode {
   #include "strs.h"
}

critcl::csources [file dirn [file norm [info scr]]]/../src/strs.c

namespace eval ::strs {
    namespace export trim_both

    critcl::cproc trim_both {char* inp} string {
        char* res = str_trim_both_alloc(inp);
        size_t len = strlen(res);
        char* buf = Tcl_Alloc (len+1);
        strncpy(buf, res, len);
        buf[len] = 0;
        return buf;
    }

    critcl::cproc hello {} int {
        return str_hello();
    }
}

if {![critcl::load]} {error "[FAIL] critcl"}

test trim_both {} -body {
    ::strs::trim_both "  foo bar  "
} -result "foo bar"


test hello_int {} -body {
    ::strs::hello
} -result 42


::tcommon finish


# Local Variables:
# mode: tcl
# fill-column: 80
# End:
